# ==============================================================================
# Router Clash Manager - Environment Variables Template
# ==============================================================================
# 复制该文件并重命名为 .env，然后填写对应的连接凭证以生效

# 1. 路由器 SSH 登录配置 (必需)
ROUTER_IP=192.168.31.1
ROUTER_USER=root
ROUTER_PASSWORD=your_router_ssh_password

# 2. Clash (Mihomo) 核心端口配置 (可选，默认为以下端口)
CLASH_PORT=9999
PROXY_PORT=7890
DNS_PORT=1053

# 3. Web 后端管理服务端口
PORT=3000

# 4. Clash 订阅链接 (必需，用于配置节点拉取与更新)
SUBSCRIPTION_URL=https://your_subscription_url

# 5. NAS 同步配置 (可选，sync_logs_periodic.sh 使用)
# NAS_IP=192.168.31.66
# NAS_USER=your_nas_username
# NAS_PASSWORD=your_nas_password

# 6. 调试模式 (可选，设为 true 时将在后台打印详细的 SSH 与 HTTP 请求流日志)
DEBUG=false
# 7. 运行环境 (可选，设为 production 时数据文件路径为 /data，否则为项目根目录)
NODE_ENV=development
