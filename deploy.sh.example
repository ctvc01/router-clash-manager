#!/bin/bash
# Clash Meta 一键同步并重启 NAS 容器脚本 (开源环境配置模板)
set -e

# === 安全配置说明 ===
# 请使用本地环境变量或创建 .env.deploy 文件来传入真实配置参数
# 严禁将真实的登录凭证与 NAS 地址硬编码在本脚本中并提交至版本控制！

REMOTE_USER="${NAS_USER:-}"
REMOTE_HOST="${NAS_HOST:-}"
REMOTE_PATH="${NAS_PATH:-/router-clash-manager}"

# 🔐 验证必需的环境变量
if [ -z "$REMOTE_USER" ] || [ -z "$REMOTE_HOST" ]; then
    echo "❌ [Error] 缺少必需的 NAS 部署环境变量"
    echo ""
    echo "请在终端先执行以下命令："
    echo "  export NAS_USER='your_nas_username'"
    echo "  export NAS_HOST='your_nas_domain_or_ip'"
    echo "  export NAS_PATH='/vol1/path_to_project'"
    echo ""
    echo "或者复制一份 deploy.sh.example 并改名为 deploy.sh，自行在本地填写（注意：deploy.sh 已写入 .gitignore，本地修改不会被提交）"
    exit 1
fi

echo "=== [INFO] 开始同步部署至远程 NAS: ${REMOTE_USER}@${REMOTE_HOST} ==="

echo "=== 1. 在 NAS 上创建部署目录 ==="
ssh ${REMOTE_USER}@${REMOTE_HOST} "mkdir -p ${REMOTE_PATH}"

echo "=== 2. 安全同步本地文件到 NAS (排除本地依赖与敏感配置) ==="
rsync -avz --delete \
  --exclude='.git/' \
  --exclude='node_modules/' \
  --exclude='.DS_Store' \
  --exclude='.env' \
  --exclude='.memory_bank/' \
  --exclude='aliases.json' \
  --exclude='device_custom.json' \
  --exclude='game_devices' \
  --exclude='ai_devices' \
  ./ ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_PATH}/

echo "=== 3. 初始化远程持久化文件，防止被挂载为文件夹 ==="
ssh ${REMOTE_USER}@${REMOTE_HOST} "touch ${REMOTE_PATH}/device_custom.json ${REMOTE_PATH}/game_devices ${REMOTE_PATH}/ai_devices ${REMOTE_PATH}/aliases.json"

echo "=== 4. 远程构建并重启容器 ==="
ssh ${REMOTE_USER}@${REMOTE_HOST} "cd ${REMOTE_PATH} && docker compose up --build --force-recreate -d"

echo "=== 5. 部署成功，容器当前状态 ==="
ssh ${REMOTE_USER}@${REMOTE_HOST} "docker ps | grep clash-meta"
